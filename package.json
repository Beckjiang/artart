{
  "name": "canvas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:web",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:web": "tsc -b && vite build",
    "build:electron": "tsup --config tsup.electron.config.ts",
    "build:pwa-server": "tsup --config tsup.pwa.config.ts",
    "build:pwa": "npm run build:web && npm run build:pwa-server",
    "build:desktop": "node scripts/desktop/build-desktop.mjs",
    "dev:desktop": "node scripts/desktop/dev.mjs",
    "start:pwa-server": "node dist-server/pwaServer.cjs",
    "start:pwa": "npm run start:pwa-server"
  },
  "dependencies": {
    "@types/three": "^0.183.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "sql.js": "^1.14.1",
    "three": "^0.183.2",
    "tldraw": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsup": "^8.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "main": "dist-electron/main.cjs",
  "build": {
    "appId": "com.canvas.desktop",
    "productName": "Canvas",
    "asar": true,
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
